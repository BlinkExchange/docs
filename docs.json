{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "venus",
  "name": "Blink",
  "colors": {
    "primary": "#22C55E",
    "light": "#22C55E",
    "dark": "#16A34A",
    "background": {
      "dark": "#0b0b0b",
      "light": "#f5f5f5"
    }
  },
  "favicon": "/favicon.svg",
  "appearance": "dark",
  "font": {
    "body": {
      "family": "Fira Code",
      "url": "https://fonts.googleapis.com/css2?family=Fira+Code:wght@300..700&display=swap",
      "weight": 400
    },
    "heading": {
      "family": "Fira Code",
      "url": "https://fonts.googleapis.com/css2?family=Fira+Code:wght@300..700&display=swap",
      "weight": 600
    },
    "code": {
      "family": "Fira Code",
      "url": "https://fonts.googleapis.com/css2?family=Fira+Code:wght@300..700&display=swap"
    }
  },
  "rounded": "none",
  "navigation": {
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Getting Started",
            "pages": ["index", "guides/quickstart", "guides/concepts"]
          },
          {
            "group": "Python SDK",
            "pages": ["sdk/python-quickstart", "sdk/python-trading", "sdk/python-websocket"]
          },
          {
            "group": "TypeScript SDK",
            "pages": ["sdk/typescript"]
          },
          {
            "group": "Market Making",
            "pages": ["guides/market-making", "guides/glft-model"]
          }
        ]
      },
      {
        "tab": "API Reference",
        "openapi": "openapi.json"
      }
    ]
  },
  "navbar": {
    "links": [
      {
        "label": "App",
        "href": "https://blink15.com"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Start Trading",
      "href": "https://blink15.com/app"
    }
  },
  "footer": {
    "socials": {
      "github": "https://github.com/BlinkExchange",
      "discord": "https://discord.gg/Gs4qZ7tWnD"
    }
  },
  "api": {
    "baseUrl": "https://api.blink15.com",
    "playground": {
      "mode": "interactive"
    }
  }
}
